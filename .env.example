# Web service
APP_PORT=8787
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:8787
VIEWER_TOKEN=change-this-to-a-long-random-secret
ADMIN_TOKEN=change-this-to-another-long-random-secret
CONFIG_PATH=/data/config.json

# Defaults shown on the web config page.
DEFAULT_IMAP_HOST=imap.gmail.com
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_MAILBOX=INBOX

# Search defaults
RECENT_DAYS=30
MAX_RESULTS=20
FETCH_LIMIT=80
IMAP_TIMEOUT_SECONDS=25
ENABLE_GMAIL_RAW=1
STRIP_PASSWORD_SPACES=1
STRICT_LOCAL_FILTER=0
